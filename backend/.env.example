# ============================================
# Signo Backend — Environment variables template
# Copy this file to .env and fill in real values
# NEVER commit the real .env
# ============================================

# MongoDB (Atlas en production, local en dev)
MONGO_URL=mongodb://localhost:27017
DB_NAME=signo

# CORS — origines autorisees pour l'API
CORS_ORIGINS=*

# ============================================
# Discord Bot (Rewards admin approval)
# Cree ton bot ici: https://discord.com/developers/applications
# ============================================
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_REWARD_CHANNEL_ID=

# ============================================
# Optionnel — Webhook admin (alertes deploiement, monitoring)
# ============================================
ADMIN_WEBHOOK_URL=
