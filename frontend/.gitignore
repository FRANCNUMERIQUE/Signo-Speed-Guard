# ============================================
# Signo Frontend — Expo SDK 54
# ============================================

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
.yarn/cache/

# Expo
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# Native build artifacts (regenerated by EAS prebuild)
android/
ios/
.kotlin/
*.orig.*

# iOS / Android signing — NEVER COMMIT THESE
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*
.metro-cache/

# Logs
npm-debug.*
yarn-debug.*
yarn-error.*

# TypeScript caches
*.tsbuildinfo

# OS
.DS_Store
*.pem

# Local env overrides only — KEEP .env committed (EAS needs EXPO_PUBLIC_BACKEND_URL)
.env*.local

# Demo / scaffold
app-example/

# ============================================
# IMPORTANT — Files that MUST be committed for EAS build:
# ============================================
# - google-services.json   (Firebase / FCM Android push notifications)
# - app.json               (Expo config)
# - package.json + yarn.lock
# - .env                   (contient EXPO_PUBLIC_BACKEND_URL public, OK a committer)
# - .easignore             (utilise par EAS CLI lors du build)
# ============================================
