# .easignore — used by EAS CLI to determine which files to upload to EAS Build.
# When this file exists, EAS uses it INSTEAD of git ls-files / .gitignore.
# This ensures google-services.json (and any other config the build needs) is uploaded
# even when the build container has no git initialized.

# Node
node_modules/

# Expo
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# Native build artifacts (regenerated by EAS prebuild)
android/
ios/
.kotlin/
*.orig.*

# Signing credentials (handled separately by EAS / Emergent)
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# Metro / Babel caches
.metro-health-check*
.metro-cache/

# Debug
npm-debug.*
yarn-debug.*
yarn-error.*

# OS
.DS_Store

# Env overrides — base .env IS uploaded so EXPO_PUBLIC_BACKEND_URL is available
.env*.local

# TypeScript caches
*.tsbuildinfo

# Demo / scaffold
app-example/

# IMPORTANT: google-services.json is INTENTIONALLY NOT ignored here —
# Firebase Cloud Messaging needs it baked into the Android build.
